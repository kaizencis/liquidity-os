# ─── Network ───
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
RPC_WSS_ENDPOINT=wss://api.mainnet-beta.solana.com

# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/liquidity_os
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Meteora DLMM ───
METEORA_API_BASE=https://dlmm-api.meteora.ag
METEORA_POOLS_WS=wss://dlmm-ws.meteora.ag
POLL_INTERVAL_MS=5000

# ─── Redis (caching / feature store) ───
REDIS_URL=redis://localhost:6379/0

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_APPROVALS_CHAT_ID=

# ─── Agents ───
HERMES_MODEL=gpt-4o
LUNA_MODEL=gpt-4o-mini
ASPRO_MODEL=gpt-4o-mini

# ─── Logging ───
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Observability ───
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318
SENTRY_DSN=
